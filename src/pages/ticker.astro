---
// src/pages/ticker.astro
const ip = import.meta.env.PUBLIC_IP;
const astroPort = import.meta.env.PUBLIC_ASTRO_PORT;
const API = `http://${ip}:${astroPort}/api`;

const defaultText = '🔴 LIVE di YouTube & TikTok — Tonton sampai habis ya!  •  🎮 Lagi main — request game di kolom komentar!  •  📱 Jangan lupa follow & nyalain notifikasi!  •  💬 Komen & chat bebas, gw baca semua kok!  •  🎁 Support stream lewat Saweria — link di bio!';
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Ticker Control</title>
    <style>
        :root { --bg: #0f0f0f; --card: #1a1a1a; }
        * { box-sizing: border-box; }
        body {
            background-color: var(--bg); color: white;
            font-family: system-ui, sans-serif;
            display: flex; flex-direction: column;
            align-items: center; min-height: 100vh;
            margin: 0; padding: 20px; gap: 16px;
        }
        .top-bar { display: flex; align-items: center; gap: 12px; width: 100%; max-width: 320px; }
        .back-btn {
            background: #1a1a1a; border: 2px solid #333; border-radius: 12px;
            color: white; padding: 8px 14px; font-size: 0.85rem; text-decoration: none; white-space: nowrap;
        }
        .status-bar {
            flex: 1; font-size: 0.8rem; padding: 5px 15px; border-radius: 20px;
            background: #222; border: 1px solid #333; text-align: center;
        }
        .big-btn {
            width: 100%; max-width: 320px; padding: 24px; border-radius: 20px;
            font-size: 1.1rem; font-weight: bold; cursor: pointer;
            transition: all 0.1s; -webkit-tap-highlight-color: transparent;
            user-select: none; border: 2px solid;
        }
        .start-btn { background: #0a2a0a; border-color: #00ff88; color: #00ff88; }
        .start-btn:active { transform: scale(0.97); background: #00ff88; color: #0a0a0a; }
        .start-btn.active { background: #00ff88; color: #0a0a0a; }
        .stop-btn { background: #2a0a0a; border-color: #ff4b2b; color: #ff4b2b; }
        .stop-btn:active { transform: scale(0.97); background: #ff4b2b; color: white; }
        .stop-btn.inactive { border-color: #333; color: #444; background: #1a1a1a; pointer-events: none; }

        /* Editor */
        .section-label {
            width: 100%; max-width: 320px;
            font-size: 0.75rem; color: #666; text-transform: uppercase;
            letter-spacing: 0.08em; margin-bottom: -8px;
        }
        .text-editor {
            width: 100%; max-width: 320px;
            background: #1a1a1a; border: 1px solid #333; border-radius: 12px;
            color: white; font-size: 0.85rem; padding: 12px 14px;
            resize: none; min-height: 90px; line-height: 1.5;
            font-family: system-ui, sans-serif; outline: none;
        }
        .text-editor:focus { border-color: #555; }
        .editor-actions {
            display: flex; gap: 8px; width: 100%; max-width: 320px;
        }
        .action-btn {
            flex: 1; padding: 10px; border-radius: 12px; font-size: 0.8rem;
            font-weight: bold; cursor: pointer; border: 1px solid #333;
            background: #1a1a1a; color: #aaa; transition: all 0.1s;
        }
        .action-btn.save { border-color: #00d4ff; color: #00d4ff; background: #0a1a22; }
        .action-btn.reset { border-color: #555; color: #666; }
        .action-btn:active { transform: scale(0.97); }

        #feedback {
            position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
            background: rgba(0,0,0,0.85); color: #00ff88; padding: 8px 16px;
            border-radius: 20px; font-size: 0.75rem; opacity: 0; transition: opacity 0.3s;
            pointer-events: none; white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="top-bar">
        <a href="/" class="back-btn">← Back</a>
        <div class="status-bar">📺 Ticker — <span style="color:#00ff88;">Ready</span></div>
    </div>

    <button class="big-btn start-btn" id="start-btn">▶ JALANIN TICKER</button>
    <button class="big-btn stop-btn inactive" id="stop-btn">⏹ STOP TICKER</button>

    <div class="section-label">✏️ Teks Ticker</div>
    <textarea class="text-editor" id="ticker-text" placeholder="Ketik teks ticker di sini..."></textarea>
    <div class="editor-actions">
        <button class="action-btn save" id="save-btn">💾 Simpan</button>
        <button class="action-btn reset" id="reset-btn">↩ Reset Default</button>
    </div>

    <div id="feedback"></div>

    <script is:inline define:vars={{ API, defaultText }}>
        let isActive = false;

        // Load teks dari localStorage kalau ada
        const saved = localStorage.getItem('tickerText');
        const textarea = document.getElementById('ticker-text');
        textarea.value = saved || defaultText;

        function showFeedback(msg, color) {
            const el = document.getElementById('feedback');
            el.innerText = msg; el.style.color = color || '#00ff88';
            el.style.opacity = '1';
            setTimeout(() => el.style.opacity = '0', 2000);
        }

        function setActive(val) {
            isActive = val;
            document.getElementById('start-btn').classList.toggle('active', val);
            document.getElementById('stop-btn').classList.toggle('inactive', !val);
        }

        function getCurrentText() {
            return textarea.value.trim() || defaultText;
        }

        async function startTicker() {
            try {
                const res = await fetch(API + '/ticker', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: getCurrentText(), active: true })
                });
                if ((await res.json()).ok) { setActive(true); showFeedback('✅ Ticker nyala!'); }
            } catch(e) { showFeedback('❌ Gagal kirim', '#ff4b2b'); }
        }

        async function stopTicker() {
            try {
                const res = await fetch(API + '/ticker', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: null, active: false })
                });
                if ((await res.json()).ok) { setActive(false); showFeedback('⏹ Ticker mati', '#ffaa00'); }
            } catch(e) { showFeedback('❌ Gagal stop', '#ff4b2b'); }
        }

        // Simpan ke localStorage
        document.getElementById('save-btn').addEventListener('click', () => {
            localStorage.setItem('tickerText', textarea.value);
            showFeedback('💾 Teks disimpan!', '#00d4ff');
        });

        // Reset ke default
        document.getElementById('reset-btn').addEventListener('click', () => {
            textarea.value = defaultText;
            localStorage.removeItem('tickerText');
            showFeedback('↩ Reset ke default', '#ffaa00');
        });

        document.getElementById('start-btn').addEventListener('pointerdown', (e) => { e.preventDefault(); startTicker(); });
        document.getElementById('stop-btn').addEventListener('pointerdown', (e) => { e.preventDefault(); stopTicker(); });
    </script>
</body>
</html>