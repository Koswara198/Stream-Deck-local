---
// src/pages/index.astro
const ip = import.meta.env.PUBLIC_IP;
const port = import.meta.env.PUBLIC_PORT;
const astroPort = import.meta.env.PUBLIC_ASTRO_PORT;
const apiToken = import.meta.env.PUBLIC_API_KEY;
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Astro Stream Deck</title>
    <style>
        :root { --bg-color: #0f0f0f; --card-bg: #1a1a1a; }
        body {
            background-color: var(--bg-color); color: white;
            font-family: system-ui, -apple-system, sans-serif;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            min-height: 100vh; margin: 0; padding: 20px;
        }
        .status-bar {
            margin-bottom: 10px; font-size: 0.8rem;
            padding: 5px 15px; border-radius: 20px;
            background: #222; border: 1px solid #333;
        }
        .deck-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 16px;
        }
        .sd-button {
            width: 110px; height: 110px;
            background: var(--card-bg);
            border: 2px solid #333; border-radius: 15px;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            cursor: pointer; transition: all 0.1s;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            -webkit-tap-highlight-color: transparent;
            text-decoration: none; color: white;
        }
        .sd-button:active {
            transform: scale(0.9);
            border-color: var(--accent-color);
            box-shadow: 0 0 15px var(--accent-color);
        }
        .sd-button.active-scene {
            border-color: var(--accent-color);
            box-shadow: 0 0 12px var(--accent-color);
        }
        .label { font-size: 0.85rem; font-weight: bold; text-align: center; padding: 0 6px; }
        .indicator { width: 30px; height: 3px; border-radius: 2px; margin-bottom: 10px; }
        #loading { font-size: 0.75rem; color: #555; margin-top: 8px; }
    </style>
</head>
<body>
    <div class="status-bar"><strong>Astro Stream Deck</strong></div>
    <div class="status-bar">
        Status: <span id="conn-text" style="color: #ffaa00;">Connecting...</span>
    </div>

    <div class="deck-grid" id="deck-grid"></div>
    <div id="loading">Memuat scene...</div>

    <script is:inline define:vars={{ ip, port, apiToken, astroPort }}>
        let socket = null;
        const statusText = document.getElementById('conn-text');
        const grid = document.getElementById('deck-grid');
        const loading = document.getElementById('loading');

        const COLORS = ['#00d4ff','#ff4b2b','#00ff88','#ffcc00','#a855f7','#ffaa00','#ec4899','#06b6d4','#84cc16','#f97316'];
        let activeSceneId = null;
        let scenesRendered = false;

        const FIXED_BUTTONS = [
            { label: '📺 TICKER', color: '#ffaa00', url: '/ticker' },
            { label: '🤡 MEME BOARD', color: '#ff00ff', url: '/meme' },
        ];

        function makeButton({ label, color, sceneId, url }) {
            const el = document.createElement(url ? 'a' : 'div');
            el.className = 'sd-button' + (sceneId ? ' scene-btn' : '');
            el.setAttribute('style', `--accent-color:${color}; width:110px; height:110px; background:#1a1a1a; border:2px solid #333; border-radius:15px; display:flex; flex-direction:column; justify-content:center; align-items:center; cursor:pointer; box-shadow:0 4px 10px rgba(0,0,0,0.3); text-decoration:none; color:white; -webkit-tap-highlight-color:transparent;`);
            el.innerHTML = `<div style="width:30px;height:3px;border-radius:2px;margin-bottom:10px;background-color:${color}"></div><span style="font-size:0.85rem;font-weight:bold;text-align:center;padding:0 6px">${label}</span>`;
            if (url) {
                el.href = url;
            } else {
                el.dataset.sceneId = sceneId;
                el.addEventListener('click', () => changeScene(sceneId));
            }
            return el;
        }

        function renderScenes(scenes) {
            if (scenesRendered) return;
            scenesRendered = true;
            loading.style.display = 'none';
            grid.innerHTML = '';

            // Scene buttons
            scenes.forEach((scene, i) => {
                grid.appendChild(makeButton({
                    label: scene.name,
                    color: COLORS[i % COLORS.length],
                    sceneId: scene.id
                }));
            });

            // Fixed buttons (ticker & meme) — style sama
            FIXED_BUTTONS.forEach(btn => grid.appendChild(makeButton(btn)));

            highlightActive();
        }

        function highlightActive() {
            grid.querySelectorAll('.scene-btn').forEach(btn => {
                btn.classList.toggle('active-scene', btn.dataset.sceneId === activeSceneId);
            });
        }

        function changeScene(sceneId) {
            if (!socket || socket.readyState !== WebSocket.OPEN) return;
            socket.send(JSON.stringify({
                jsonrpc: "2.0", id: 200,
                method: "makeSceneActive",
                params: { resource: "ScenesService", args: [sceneId] }
            }));
            activeSceneId = sceneId;
            highlightActive();
        }

        function sendCommand(resource, method, args, id) {
            if (!socket || socket.readyState !== WebSocket.OPEN) return;
            socket.send(JSON.stringify({
                jsonrpc: "2.0", id: id || Date.now(), method,
                params: { resource, args: args || [] }
            }));
        }

        function connect() {
            socket = new WebSocket('ws://' + ip + ':' + port + '/api/websocket');
            socket.onopen = () => sendCommand("TcpServerService", "auth", [apiToken], 1);

            socket.onmessage = (event) => {
                const data = JSON.parse(event.data);

                if (data.id === 1 && !data.error) {
                    statusText.innerText = 'Connected ✅';
                    statusText.style.color = '#00ff88';
                    sendCommand("ScenesService", "getScenes", [], 100);
                    sendCommand("ScenesService", "activeScene", [], 101);
                }

                if (data.id === 100 && data.result) renderScenes(data.result);

                if (data.id === 101 && data.result) {
                    activeSceneId = data.result.id;
                    highlightActive();
                }
            };

            socket.onclose = () => {
                statusText.innerText = 'Connecting... 🔄';
                statusText.style.color = '#ffaa00';
                setTimeout(connect, 3000);
            };

            socket.onerror = () => {
                statusText.innerText = 'Streamlabs offline ⚠️';
                statusText.style.color = '#ffaa00';
            };
        }

        connect();
    </script>
</body>
</html>